{
  "name": "distributed-event-ordering",
  "version": "1.0.0",
  "description": "Simulation of a resilient distributed event ordering system using Lamport and vector clocks.",
  "main": "event-collector/collector.js",
  "scripts": {
    "start:order": "node services/order-service/index.js",
    "start:payment": "node services/payment-service/index.js",
    "start:restaurant": "node services/restaurant-service/index.js",
    "start:delivery": "node services/delivery-service/index.js",
    "start:collector": "node event-collector/collector.js",
    "start:all": "node scripts/startAll.js",
    "dev": "node scripts/startAll.js",
    "check": "npm run check:static",
    "check:static": "node scripts/check.js static",
    "check:live": "node scripts/check.js live",
    "test": "node scripts/check.js test"
  },
  "keywords": [
    "distributed-systems",
    "lamport-clock",
    "vector-clock",
    "redis",
    "mongodb",
    "simulation"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "joi": "^17.13.3",
    "mongoose": "^8.13.0",
    "redis": "^4.7.0",
    "uuid": "^11.1.0"
  }
}
