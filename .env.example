# Local development configuration for the distributed-event-ordering project

# Infrastructure connections
MONGO_URI=mongodb://127.0.0.1:27017/distributed_event_ordering
REDIS_URL=redis://127.0.0.1:6379

# Collector configuration
COLLECTOR_PORT=4000

# Service port reference values
# Note: the current implementation uses fixed ports from shared/constants.js.
ORDER_SERVICE_PORT=3001
PAYMENT_SERVICE_PORT=3002
RESTAURANT_SERVICE_PORT=3003
DELIVERY_SERVICE_PORT=3004

# Dashboard note:
# The static dashboard auto-detects the collector API base when possible,
# or falls back to http://localhost:4000 when opened directly from file://.
